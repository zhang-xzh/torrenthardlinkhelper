<Window x:Class="TorrentHardLinkHelper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:models="clr-namespace:TorrentHardLinkHelper.Models"
        DataContext="{Binding Source={StaticResource Locator}, Path=Main}"
        Title="Torrent HardLink Helper v1.0" Height="850" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Torrent File:" HorizontalContentAlignment="Right" VerticalAlignment="Center" />
            <Label Grid.Row="1" Grid.Column="0" Content="Source Folder:" HorizontalContentAlignment="Right" VerticalAlignment="Center" />
            <Label Grid.Row="2" Grid.Column="0" Content="Output BaseFolder:" HorizontalContentAlignment="Right" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" Text="{Binding TorrentFile}"
                     AllowDrop="True" PreviewDragOver="TextBox_PreviewDragOver" Drop="TorrentFile_Drop" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" Text="{Binding SourceFolder}"
                     AllowDrop="True" PreviewDragOver="TextBox_PreviewDragOver" Drop="SourceFolder_Drop" />
            <TextBox Grid.Row="2" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" Text="{Binding OutputBaseFolder}"
                     AllowDrop="True" PreviewDragOver="TextBox_PreviewDragOver" Drop="OutputBaseFolder_Drop" />
            <Button Grid.Row="0" Grid.Column="2" Content="Select" Margin="5" Padding="10,5" Command="{Binding SelectTorrentFileCommand}" />
            <Button Grid.Row="1" Grid.Column="2" Content="Select" Margin="5" Padding="10,5" Command="{Binding SelectSourceFolderCommand}" />
            <Button Grid.Row="2" Grid.Column="2" Content="Select" Margin="5" Padding="10,5" Command="{Binding SelectOutputBaseFolderCommand}" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <HierarchicalDataTemplate x:Key="EntityTemplate" DataType="models:EntityModel" ItemsSource="{Binding Entities}">
                    <TextBlock Text="{Binding Name}" Foreground="{Binding TextColor, Mode=OneWay}" />
                </HierarchicalDataTemplate>
            </Grid.Resources>
            <Label Grid.Row="0" Grid.Column="0" Content="Source Files" />
            <Label Grid.Row="0" Grid.Column="1" Content="Torrent Files" />
            <TreeView x:Name="TvFileSystem" Grid.Row="1" Grid.Column="0" Margin="5" ItemsSource="{Binding FileSystemEntityModel}" ItemTemplate="{StaticResource EntityTemplate}" />
            <TreeView x:Name="TvTorrent" Grid.Row="1" Grid.Column="1" Margin="5" ItemsSource="{Binding TorrentEntityModel}" ItemTemplate="{StaticResource EntityTemplate}" />
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Expand All" Margin="5" Command="{Binding ExpandAllCommand}" CommandParameter="{Binding ElementName=TvFileSystem}" />
                <Button Content="Collapse All" Margin="5" Command="{Binding CollapseAllCommand}" CommandParameter="{Binding ElementName=TvFileSystem}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Expand All" Margin="5" Command="{Binding ExpandAllCommand}" CommandParameter="{Binding ElementName=TvTorrent}" />
                <Button Content="Collapse All" Margin="5" Command="{Binding CollapseAllCommand}" CommandParameter="{Binding ElementName=TvTorrent}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Output Folder Name:" />
                <TextBox Grid.Column="1" Text="{Binding OutputName}" VerticalContentAlignment="Center" IsReadOnly="{Binding IsOutputNameReadonly, Mode=OneWay}" />
                <ComboBox Grid.Column="2" ItemsSource="{Binding OutputNameTypes}" SelectedIndex="0" Width="120" Margin="10,0,0,0" Text="{Binding OutputNameType}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="SelectionChanged">
                            <b:InvokeCommandAction Command="{Binding OutputNameTypeChangedCommand}" PassEventArgsToCommand="True" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ComboBox>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Just" />
                    <Run Text="COPY" FontWeight="Bold" />
                    <Run Text="not Hard-Link when filesize is below: " />
                </TextBlock>
                <TextBox VerticalContentAlignment="Center" Margin="5,0,0,0" Width="50" Text="{Binding CopyLimitSize}" HorizontalContentAlignment="Right" />
                <Label Content="KB" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="Hard-Link Tool" Padding="10,5" Margin="5" Command="{Binding HardlinkToolCommand}" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Analyse" Padding="10,5" Margin="5" Command="{Binding AnalyseCommand}" />
            <Button Content="Hard-Link" Padding="10,5" Margin="5" Command="{Binding LinkCommand}" />
            <Button Content="Soft-Link Linux" Padding="10,5" Margin="5" Command="{Binding LinkLinuxCommand}" />
            <Button Content="Hard-Link Linux" Padding="10,5" Margin="5" Command="{Binding HardlinkLinuxCommand}" />
            <Button Content="Move Linux" Padding="10,5" Margin="5" Command="{Binding MoveLinuxCommand}" />
        </StackPanel>
        <StatusBar Grid.Row="4" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}" Background="Transparent" />
            </StatusBarItem>
            <StatusBarItem Width="150" HorizontalAlignment="Right">
                <ProgressBar Minimum="0" Maximum="{Binding MaxProcess, Mode=OneWay}" Value="{Binding CurPorcess, Mode=OneWay}" Height="15" Width="140" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>